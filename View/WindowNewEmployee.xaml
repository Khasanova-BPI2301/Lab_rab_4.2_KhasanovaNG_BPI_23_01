<Window x:Class="Lab_rab_4._2_KhasanovaNG_BPI_23_01.View.WindowNewEmployee"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Lab_rab_4._2_KhasanovaNG_BPI_23_01.View"
        mc:Ignorable="d"
         Title="Сотрудник" Height="300" Width="350">
    <StackPanel Margin="10">
        <TextBlock Text="Фамилия:" Margin="0,0,0,5"/>
        <TextBox Text="{Binding LastName}" Height="25"/>

        <TextBlock Text="Имя:" Margin="0,10,0,5"/>
        <TextBox Text="{Binding FirstName}" Height="25"/>

        <TextBlock Text="Дата рождения:" Margin="0,10,0,5"/>
        <DatePicker SelectedDate="{Binding Birthday}" Height="25"/>

        <TextBlock Text="Должность:" Margin="0,10,0,5"/>
        <ComboBox x:Name="CbRole"
                  DisplayMemberPath="NameRole"
                  SelectedValuePath="Id"
                  Height="25"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Сохранить" Click="Save_Click" Width="80" Margin="0,0,10,0"/>
            <Button Content="Отмена" Click="Cancel_Click" Width="80"/>
        </StackPanel>
    </StackPanel>
</Window>