<Window x:Class="Lab_rab_4._2_KhasanovaNG_BPI_23_01.View.WindowRole"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Lab_rab_4._2_KhasanovaNG_BPI_23_01.View"
        mc:Ignorable="d"
                 Title="Должности" Height="350" Width="300">
    <StackPanel Background="#FFD8D8D8">
        <Label Margin="5" HorizontalAlignment="Center">Список должностей сотрудников</Label>
        <ListView ItemsSource="{Binding ListRole}" 
                  SelectedItem="{Binding SelectedRole}"
                  Background="#FFD3CDCD" Height="200">
            <ListView.View>
                <GridView>
                    <GridView.Columns>
                        <GridViewColumn Header="Код" Width="50" DisplayMemberBinding="{Binding Id}"/>
                        <GridViewColumn Header="Наименование должности" DisplayMemberBinding="{Binding NameRole}"/>
                    </GridView.Columns>
                </GridView>
            </ListView.View>
        </ListView>
        <StackPanel Orientation="Horizontal" Background="#FFE4E0E0" Margin="0,10,0,0">
            <Button Content="Добавить" Height="25" Margin="10,0,5,0" Command="{Binding AddRole}"/>
            <Button Content="Редактировать" Height="25" Margin="5,0,5,0" Command="{Binding EditRole}"/>
            <Button Content="Удалить" Height="25" Margin="5,0,10,0" Command="{Binding DeleteRole}"/>
        </StackPanel>
    </StackPanel>
    
</Window>

